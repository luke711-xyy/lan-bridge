{
  "name": "lan-bridge",
  "version": "0.1.0",
  "description": "Low-latency desktop file and text bridge for Windows and macOS on the same LAN.",
  "main": "dist-electron/main/main.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:watch:electron\" \"npm:dev:renderer\" \"npm:start:electron\"",
    "dev:renderer": "vite --host 0.0.0.0 --port 5180 --strictPort",
    "watch:electron": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "start:electron": "wait-on tcp:5180 file:dist-electron/main/main.js && electron .",
    "build": "npm run clean && npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "dist": "npm run build && electron-builder",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item dist -Recurse -Force }; if (Test-Path dist-electron) { Remove-Item dist-electron -Recurse -Force }\""
  },
  "build": {
    "appId": "com.codex.lanbridge",
    "productName": "Lan Bridge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
